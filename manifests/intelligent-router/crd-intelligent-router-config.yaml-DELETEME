apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metadata:
  name: intelligentrouterconfigs.vllm.ai
spec:
  group: vllm.ai
  names:
    kind: IntelligentRouterConfig
    listKind: IntelligentRouterConfigList
    plural: intelligentrouterconfigs
    singular: intelligentrouterconfig
    shortNames:
      - irc
  scope: Namespaced
  versions:
    - name: v1alpha1
      served: true
      storage: true
      schema:
        openAPIV3Schema:
          type: object
          properties:
            spec:
              type: object
              required: [pool, weights]
              properties:
                pool:
                  type: object
                  required: [defaultModel, models]
                  properties:
                    defaultModel:
                      type: string
                      description: "Model name to use when no routing decision can be made."
                    models:
                      type: array
                      minItems: 1
                      items:
                        type: object
                        required: [name]
                        properties:
                          name:
                            type: string
                            description: "Unique identifier for the model (e.g. gpt-4o-mini)."
                          initialAverageLatencyMs:
                            type: number
                            minimum: 0
                            description: "Initial seed latency in ms. Updated at runtime from observed requests."
                          qualityScores:
                            type: object
                            description: "Map of domain name to quality score [0,1]. Higher = better fit for that domain."
                            additionalProperties:
                              type: number
                              minimum: 0
                              maximum: 1
                          costScore:
                            type: number
                            minimum: 0
                            maximum: 1
                            description: "Relative cost of the model, normalised to [0,1]. Higher = more expensive."
                          endpointType:
                            type: string
                            description: "Endpoint type: public or onprem."
                          aiInfrastructureType:
                            type: string
                            description: "Infrastructure type: cpu, gpu_a100, gpu_h100, etc."
                weights:
                  type: object
                  description: "Scoring weights for the routing utility function."
                  properties:
                    quality:
                      type: number
                      minimum: 0
                      description: "Weight for domain quality score (positive contributor)."
                    latency:
                      type: number
                      minimum: 0
                      description: "Weight for latency penalty (higher latency → lower score)."
                    cost:
                      type: number
                      minimum: 0
                      description: "Weight for cost penalty (higher cost → lower score). Amplified under budget pressure."
                keywordRules:
                  type: array
                  description: "Keyword-based classification rules for domain detection."
                  items:
                    type: object
                    required: [name, keywords, operator]
                    properties:
                      name:
                        type: string
                        description: "Domain name this rule classifies into (e.g. finance, health)."
                      keywords:
                        type: array
                        items:
                          type: string
                        description: "List of keywords to match against the user message."
                      operator:
                        type: string
                        enum: [AND, OR, NOR]
                        description: "AND: all keywords must match. OR: any keyword matches. NOR: no keyword must match."
                      caseSensitive:
                        type: boolean
                        description: "Whether matching is case-sensitive. Defaults to false."
                mlClassifier:
                  type: object
                  description: "BERT-based ML domain classifier (requires binary built with CGO and model weights mounted)."
                  properties:
                    enabled:
                      type: boolean
                      description: "Set true to activate the ML classifier."
                    modelPath:
                      type: string
                      description: "Filesystem path to the SafeTensors model directory."
                    mappingPath:
                      type: string
                      description: "Path to category_mapping.json produced during model training."
                    numClasses:
                      type: integer
                      minimum: 0
                      description: "Number of output classes (0 = auto-detect from model weights)."
                    useCPU:
                      type: boolean
                      description: "Force CPU inference even when a GPU is available."
                    threshold:
                      type: number
                      minimum: 0
                      maximum: 1
                      description: "Minimum confidence score [0,1] to accept a classification result."
                tokenBudget:
                  type: object
                  description: "Per-API-key token budget configuration for usage-based routing."
                  properties:
                    enabled:
                      type: boolean
                      description: "Enable token budget based routing pressure."
                    threshold:
                      type: integer
                      minimum: 0
                      description: "Token count above which budget pressure begins."
                    quota:
                      type: integer
                      minimum: 0
                      description: "Token count at which maximum cost pressure is applied."
                    windowSeconds:
                      type: integer
                      minimum: 1
                      description: "Sliding window duration in seconds for token counting."
      additionalPrinterColumns:
        - name: Default-Model
          type: string
          jsonPath: .spec.pool.defaultModel
        - name: Models
          type: integer
          jsonPath: .spec.pool.models[*].name
        - name: Budget-Enabled
          type: boolean
          jsonPath: .spec.tokenBudget.enabled
        - name: Age
          type: date
          jsonPath: .metadata.creationTimestamp
